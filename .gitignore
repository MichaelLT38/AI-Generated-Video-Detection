# NOTE: git only treats '#' as a comment when it is the FIRST character on a
# line. Inline comments after a pattern (e.g. "examples/  # notes") are NOT
# supported and become part of the pattern, so every comment lives on its own
# line below.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Project-specific (notes, caches, generated models) ---
