# personal use, not versioned).
examples/
# Session notes (not for distribution)
DISCUSSION_LOG.md
# Calibration feature cache
.feature_cache.json
# Generated, user-specific model
calibration.json
# Local helper / test scripts (not part of the shipped tool)
render_fp_tests.py
dump_real_fingerprints.py

